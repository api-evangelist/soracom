    {
      "info": {
        "name": "API Sandbox: Operator",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Creates an operator account",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api-sandbox.soracom.io/v1/sandbox/init",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Performs complex signup process at once, including registering dummy payment method. Specify `email` and `password` for an operator which will be created on sandbox, `authKeyId` and `authKey` for a real operator on the production environment. An API Key and an API Token will be included in the response if successful. Use the API Key and the API Token to requests afterwards."
        },
        {
          "info": {
            "name": "Deletes an operator",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api-sandbox.soracom.io/v1/sandbox/operators/:operator_id",
            "params": [
              {
                "name": "operator_id",
                "value": "",
                "type": "path",
                "description": "Operator ID"
              }
            ]
          },
          "docs": "Deletes the specified operator."
        },
        {
          "info": {
            "name": "Gets a signup token",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api-sandbox.soracom.io/v1/sandbox/operators/token/:email",
            "params": [
              {
                "name": "email",
                "value": "",
                "type": "path",
                "description": "Email"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Retrieves a 'signup token' for registration confirmation. Please specify a pair of AuthKeyId and AuthKey of a SAM user on the production environment to check if the caller has a valid account on it."
        }
      ]
    },
    {
