            "method": "GET",
            "url": "https://api.soracom.io/v1/lagoon/image/link",
            "auth": {
              "type": "apikey",
              "key": "X-Soracom-API-Key",
              "value": "{{X-Soracom-API-Key}}",
              "placement": "header"
            }
          },
          "docs": "Get a custom icon image link of Soracom Lagoon Console."
